{% doc %}
  @prompt
    bemefits table
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-benefits-table-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    display: block;
  }

  .ai-benefits-table__container-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
    {% if block.settings.enable_shadow %}
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    {% endif %}
    {% if block.settings.enable_border %}
      border: 1px solid {{ block.settings.border_color }};
    {% endif %}
  }

  .ai-benefits-table__header-{{ ai_gen_id }} {
    background-color: {{ block.settings.header_bg_color }};
    padding: {{ block.settings.header_padding }}px;
    text-align: {{ block.settings.header_alignment }};
  }

  .ai-benefits-table__title-{{ ai_gen_id }} {
    margin: 0;
    color: {{ block.settings.header_text_color }};
    font-size: {{ block.settings.title_size }}px;
  }

  .ai-benefits-table__subtitle-{{ ai_gen_id }} {
    margin: 8px 0 0;
    color: {{ block.settings.header_text_color }};
    opacity: 0.8;
    font-size: {{ block.settings.subtitle_size }}px;
  }

  .ai-benefits-table__table-{{ ai_gen_id }} {
    width: 100%;
    border-collapse: collapse;
  }

  .ai-benefits-table__row-{{ ai_gen_id }} {
    border-bottom: 1px solid {{ block.settings.row_border_color }};
  }

  .ai-benefits-table__row-{{ ai_gen_id }}:last-child {
    border-bottom: none;
  }

  .ai-benefits-table__row-{{ ai_gen_id }}:nth-child(even) {
    background-color: {{ block.settings.row_alternate_bg }};
  }

  .ai-benefits-table__cell-{{ ai_gen_id }} {
    padding: {{ block.settings.cell_padding }}px;
    vertical-align: middle;
  }

  .ai-benefits-table__cell-{{ ai_gen_id }}:first-child {
    width: 50%;
    font-weight: 600;
    color: {{ block.settings.label_color }};
    font-size: {{ block.settings.label_size }}px;
  }

  .ai-benefits-table__cell-{{ ai_gen_id }}:last-child {
    width: 50%;
    color: {{ block.settings.value_color }};
    font-size: {{ block.settings.value_size }}px;
    text-align: {{ block.settings.value_alignment }};
  }

  .ai-benefits-table__icon-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    margin-right: 8px;
    vertical-align: middle;
  }

  .ai-benefits-table__icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    fill: {{ block.settings.icon_color }};
  }

  .ai-benefits-table__checkmark-{{ ai_gen_id }} {
    color: {{ block.settings.checkmark_color }};
    font-size: {{ block.settings.icon_size }}px;
    font-weight: bold;
  }

  @media screen and (max-width: 749px) {
    .ai-benefits-table__title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.8);
    }

    .ai-benefits-table__subtitle-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subtitle_size }}px * 0.8);
    }

    .ai-benefits-table__cell-{{ ai_gen_id }} {
      padding: {{ block.settings.cell_padding | times: 0.7 }}px;
      font-size: 14px;
    }

    .ai-benefits-table__cell-{{ ai_gen_id }}:first-child,
    .ai-benefits-table__cell-{{ ai_gen_id }}:last-child {
      font-size: 14px;
    }
  }
{% endstyle %}

<ai-benefits-table-{{ ai_gen_id }} class="ai-benefits-table-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-benefits-table__container-{{ ai_gen_id }}">
    {% if block.settings.show_header %}
      <div class="ai-benefits-table__header-{{ ai_gen_id }}">
        {% if block.settings.title != blank %}
          <h2 class="ai-benefits-table__title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
        {% endif %}
        {% if block.settings.subtitle != blank %}
          <p class="ai-benefits-table__subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
        {% endif %}
      </div>
    {% endif %}

    <table class="ai-benefits-table__table-{{ ai_gen_id }}">
      <tbody>
        {% for i in (1..10) %}
          {% liquid
            assign label_key = 'benefit_' | append: i | append: '_label'
            assign value_key = 'benefit_' | append: i | append: '_value'
            assign show_icon_key = 'benefit_' | append: i | append: '_show_icon'
            
            assign label = block.settings[label_key]
            assign value = block.settings[value_key]
            assign show_icon = block.settings[show_icon_key]
          %}

          {% if label != blank and value != blank %}
            <tr class="ai-benefits-table__row-{{ ai_gen_id }}">
              <td class="ai-benefits-table__cell-{{ ai_gen_id }}">
                {% if show_icon %}
                  <span class="ai-benefits-table__icon-{{ ai_gen_id }}">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="20 6 9 17 4 12"></polyline>
                    </svg>
                  </span>
                {% endif %}
                {{ label }}
              </td>
              <td class="ai-benefits-table__cell-{{ ai_gen_id }}">
                {% if block.settings.show_checkmarks and value == 'yes' %}
                  <span class="ai-benefits-table__checkmark-{{ ai_gen_id }}">✓</span>
                {% else %}
                  {{ value }}
                {% endif %}
              </td>
            </tr>
          {% endif %}
        {% endfor %}
      </tbody>
    </table>
  </div>
</ai-benefits-table-{{ ai_gen_id }}>

<script>
  (function() {
    class AiBenefitsTable{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('ai-benefits-table-{{ ai_gen_id }}', AiBenefitsTable{{ ai_gen_id }});
  })();
</script>

